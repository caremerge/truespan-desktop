# eSigner.com Cloud Code Signing Credentials
# IMPORTANT: Copy this file to .env and fill in all values below with your actual eSigner credentials

# Your eSigner.com email address (from the portal)
ESIGNER_USERNAME=

# Your eSigner.com password
ESIGNER_PASSWORD=

# Your credential ID (Click "SHOW MY SIGNING CREDENTIALS" in eSigner portal to find this)
ESIGNER_CREDENTIAL_ID=

# Your TOTP secret code (Copy from the text box in your eSigner portal - the one visible in your screenshot)
# Example: Ip8/Gq+Bhrc/UGu+2y/z2v/UVGB6WP9CBZKAIbHckdOiQ=
ESIGNER_TOTP_SECRET=

# Optional: If you move CodeSignTool, update this path
# CODESIGNTOOL_PATH=C:\Users\ryanm\CodeSignTool-v1.3.2-windows\CodeSignTool.bat


